APP_NAME="Mohi Portfolio"
APP_ENV=production
APP_KEY=                         # php artisan key:generate --show
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://mohiebi.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=mariadb                  # Docker service name — do NOT change
DB_PORT=3306
DB_DATABASE=portfolio_db
DB_USERNAME=portfolio_user
DB_PASSWORD=                     # FILL IN

DB_ROOT_PASSWORD=                # MariaDB root password — FILL IN

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=file
QUEUE_CONNECTION=sync

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=hello@mohiebi.com
MAIL_FROM_NAME="${APP_NAME}"

# Add any socialite / OAuth keys below
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
